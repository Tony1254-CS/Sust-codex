# Gemini API key (required for LLM enrichment; deterministic fallback works without it)
GEMINI_API_KEY=

# Enable LLM enrichment (set to "true" to enable; defaults to false)
LLM_ENABLED=

# LLM timeout in milliseconds (default: 5500)
LLM_TIMEOUT_MS=

# Log level (debug | info | warn | error; default: info)
LOG_LEVEL=
